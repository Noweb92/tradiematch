# =============================================================================
# TradieMatch V1 — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Local development uses these. Production sets the same vars in Vercel.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for auth + DB)
# -----------------------------------------------------------------------------
# Get from https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe (required for tradie subscriptions)
# -----------------------------------------------------------------------------
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs — create 3 recurring AUD products: Basic $49 / Pro $89 / Elite $149
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=

# -----------------------------------------------------------------------------
# Australian Business Register (free)
# -----------------------------------------------------------------------------
# Register for a GUID at https://abr.business.gov.au/Tools/WebServices
ABR_GUID=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# https://resend.com — 3K emails/month free
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@tradiematch.com.au

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TradieMatch

# -----------------------------------------------------------------------------
# Cron secret (for /api/cron/* endpoints)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
CRON_SECRET=

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# Comma-separated emails that auto-receive the 'admin' role on first login.
ADMIN_EMAILS=marwan@tradiematch.com.au

# -----------------------------------------------------------------------------
# Optional analytics & monitoring (free tiers)
# -----------------------------------------------------------------------------
# https://posthog.com — 1M events/month free
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# https://sentry.io — 5K errors/month free
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Optional: Upstash Redis (rate limiting)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
